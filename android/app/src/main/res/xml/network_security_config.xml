<?xml version="1.0" encoding="utf-8"?>
<network-security-config>
    <!-- 
    Network Security Configuration for Aura Music App
    
    Allows cleartext (HTTP) traffic for local development:
    - Emulator: 10.0.2.2 (maps to host machine's localhost)
    - Physical device: 192.168.x.x (local network IPs)
    
    This is required for Android 9+ (API 28+) which blocks HTTP by default.
    In production, use HTTPS only and remove this configuration.
    -->
    
    <base-config cleartextTrafficPermitted="true">
        <!-- Allow cleartext for local development networks -->
        <trust-anchors>
            <certificates src="system" />
        </trust-anchors>
    </base-config>
    
    <!-- 
    Domain-specific configuration for development
    Allows cleartext traffic only for local development IPs
    -->
    <domain-config cleartextTrafficPermitted="true">
        <!-- Emulator IP -->
        <domain includeSubdomains="true">10.0.2.2</domain>
        <!-- Physical device - actual server IP -->
        <domain includeSubdomains="true">192.168.1.3</domain>
        <!-- Common local network IPs (for flexibility) -->
        <domain includeSubdomains="true">192.168.1.5</domain>
        <domain includeSubdomains="true">192.168.0.100</domain>
        <domain includeSubdomains="true">localhost</domain>
    </domain-config>
</network-security-config>

