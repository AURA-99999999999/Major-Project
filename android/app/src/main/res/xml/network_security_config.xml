<?xml version="1.0" encoding="utf-8"?>
<network-security-config>
    <!-- Debug/Local development configuration - allows cleartext for 10.0.2.2 (emulator) and local IPs -->
    <domain-config cleartextTrafficPermitted="true">
        <domain includeSubdomains="true">10.0.2.2</domain>
        <domain includeSubdomains="true">127.0.0.1</domain>
        <domain includeSubdomains="true">localhost</domain>
        <domain includeSubdomains="true">192.168.1.6</domain>
    </domain-config>
    
    <!-- Production configuration - HTTPS only for render.com -->
    <domain-config cleartextTrafficPermitted="false">
        <domain includeSubdomains="true">aura-b7vm.onrender.com</domain>
        <trust-anchors>
            <certificates src="system" />
        </trust-anchors>
    </domain-config>
    
    <!-- Default configuration for other domains -->
    <base-config cleartextTrafficPermitted="false">
        <trust-anchors>
            <certificates src="system" />
        </trust-anchors>
    </base-config>
</network-security-config>

